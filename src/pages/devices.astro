

---
import MainLayout from '../layouts/main.astro';
import Navbar from '../components/Navbar';
import { Plus } from 'lucide-react';
import { baseUrl } from '../lib/base-url';

const devices = [
  { id: 'DEV-001', name: 'Temperature Sensor A1', status: true, location: 'Warehouse North' },
  { id: 'DEV-002', name: 'Humidity Monitor B2', status: true, location: 'Office Floor 2' },
  { id: 'DEV-003', name: 'Pressure Gauge C3', status: false, location: 'Production Line 1' },
  { id: 'DEV-004', name: 'Motion Detector D4', status: true, location: 'Entrance Hall' },
  { id: 'DEV-005', name: 'Temperature Sensor A2', status: true, location: 'Warehouse South' },
  { id: 'DEV-006', name: 'Air Quality Monitor E5', status: false, location: 'Office Floor 3' },
  { id: 'DEV-007', name: 'Light Sensor F6', status: true, location: 'Parking Lot' },
  { id: 'DEV-008', name: 'Water Level Sensor G7', status: true, location: 'Storage Tank A' },
];
---

<MainLayout>
  <Navbar client:only="react" />
  
  <div class="min-h-screen bg-slate-900 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-4xl font-bold text-white font-heading">Devices</h1>
        <button id="addDeviceBtn" class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-md flex items-center gap-2 transition-colors">
          <Plus className="w-5 h-5" />
          Add Device
        </button>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {devices.map((device) => (
          <a
            href={`${baseUrl}/device/${device.id}`}
            target="_blank"
            class="bg-slate-800 border border-slate-700 rounded-lg p-6 hover:border-blue-500 transition-all hover:shadow-lg hover:shadow-blue-500/20 cursor-pointer"
          >
            <div class="flex items-start justify-between mb-4">
              <div class="w-12 h-12 bg-blue-500/20 rounded-lg flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                </svg>
              </div>
              <div class={`flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium ${device.status ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}`}>
                <div class={`w-2 h-2 rounded-full ${device.status ? 'bg-green-400 animate-pulse' : 'bg-red-400'}`}></div>
                {device.status ? 'Online' : 'Offline'}
              </div>
            </div>
            
            <h3 class="text-lg font-bold text-white mb-2 font-heading">{device.name}</h3>
            <div class="space-y-1">
              <p class="text-sm text-slate-400">
                <span class="font-medium">ID:</span> {device.id}
              </p>
              <p class="text-sm text-slate-400">
                <span class="font-medium">Location:</span> {device.location}
              </p>
            </div>
            
            <div class="mt-4 pt-4 border-t border-slate-700">
              <div class="flex items-center justify-between text-xs">
                <span class="text-slate-400">Live Status</span>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" checked={device.status} class="sr-only peer" onclick="event.preventDefault(); event.stopPropagation();">
                  <div class="w-11 h-6 bg-slate-700 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-500 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-500"></div>
                </label>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
  
  <!-- Add Device Modal Container -->
  <div id="addDeviceModalRoot"></div>
</MainLayout>

<script>
  document.getElementById('addDeviceBtn')?.addEventListener('click', async () => {
    const { default: AddDeviceModal } = await import('../components/AddDeviceModal');
    const { createRoot } = await import('react-dom/client');
    const { createElement } = await import('react');
    
    const container = document.getElementById('addDeviceModalRoot');
    if (!container) return;
    
    const root = createRoot(container);
    
    const handleClose = () => {
      root.unmount();
    };
    
    root.render(createElement(AddDeviceModal, { isOpen: true, onClose: handleClose }));
  });
</script>

<style>
  .lucide {
    display: inline-block;
  }
</style>


