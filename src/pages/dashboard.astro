---
import MainLayout from '../layouts/main.astro';
import Navbar from '../components/Navbar';
---

<MainLayout>
  <Navbar client:only="react" />
  
  <div class="min-h-screen bg-slate-900 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-bold text-white mb-8 font-heading">Dashboard</h1>
      
      <!-- Device Status Summary -->
      <div class="grid md:grid-cols-4 gap-6 mb-8">
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-slate-400 text-sm">Total Devices</span>
            <div class="w-3 h-3 bg-blue-400 rounded-full"></div>
          </div>
          <div class="text-3xl font-bold text-white">24</div>
        </div>
        
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-slate-400 text-sm">Online</span>
            <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
          </div>
          <div class="text-3xl font-bold text-green-400">21</div>
        </div>
        
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-slate-400 text-sm">Offline</span>
            <div class="w-3 h-3 bg-red-400 rounded-full"></div>
          </div>
          <div class="text-3xl font-bold text-red-400">3</div>
        </div>
        
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <div class="flex items-center justify-between mb-2">
            <span class="text-slate-400 text-sm">Alerts</span>
            <div class="w-3 h-3 bg-yellow-400 rounded-full"></div>
          </div>
          <div class="text-3xl font-bold text-yellow-400">2</div>
        </div>
      </div>
      
      <!-- Charts Section -->
      <div class="grid lg:grid-cols-2 gap-6 mb-8">
        <!-- Temperature Chart -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <h2 class="text-xl font-bold text-white mb-4 font-heading">Temperature Trends</h2>
          <div class="bg-slate-900 rounded-lg p-6 h-64 flex items-center justify-center border border-slate-700">
            <svg class="w-full h-full" viewBox="0 0 400 200">
              <!-- Grid lines -->
              <line x1="40" y1="20" x2="40" y2="180" stroke="#475569" stroke-width="1"/>
              <line x1="40" y1="180" x2="380" y2="180" stroke="#475569" stroke-width="1"/>
              
              <!-- Y-axis labels -->
              <text x="25" y="25" fill="#94a3b8" font-size="10">30°C</text>
              <text x="25" y="65" fill="#94a3b8" font-size="10">25°C</text>
              <text x="25" y="105" fill="#94a3b8" font-size="10">20°C</text>
              <text x="25" y="145" fill="#94a3b8" font-size="10">15°C</text>
              <text x="25" y="185" fill="#94a3b8" font-size="10">10°C</text>
              
              <!-- X-axis labels -->
              <text x="60" y="195" fill="#94a3b8" font-size="10">00:00</text>
              <text x="140" y="195" fill="#94a3b8" font-size="10">06:00</text>
              <text x="220" y="195" fill="#94a3b8" font-size="10">12:00</text>
              <text x="300" y="195" fill="#94a3b8" font-size="10">18:00</text>
              
              <!-- Temperature line -->
              <polyline
                points="40,140 80,120 120,130 160,110 200,100 240,115 280,105 320,95 360,90"
                fill="none"
                stroke="#3b82f6"
                stroke-width="2"
              />
              
              <!-- Data points -->
              <circle cx="40" cy="140" r="3" fill="#3b82f6"/>
              <circle cx="80" cy="120" r="3" fill="#3b82f6"/>
              <circle cx="120" cy="130" r="3" fill="#3b82f6"/>
              <circle cx="160" cy="110" r="3" fill="#3b82f6"/>
              <circle cx="200" cy="100" r="3" fill="#3b82f6"/>
              <circle cx="240" cy="115" r="3" fill="#3b82f6"/>
              <circle cx="280" cy="105" r="3" fill="#3b82f6"/>
              <circle cx="320" cy="95" r="3" fill="#3b82f6"/>
              <circle cx="360" cy="90" r="3" fill="#3b82f6"/>
            </svg>
          </div>
        </div>
        
        <!-- Humidity Chart -->
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <h2 class="text-xl font-bold text-white mb-4 font-heading">Humidity Trends</h2>
          <div class="bg-slate-900 rounded-lg p-6 h-64 flex items-center justify-center border border-slate-700">
            <svg class="w-full h-full" viewBox="0 0 400 200">
              <!-- Grid lines -->
              <line x1="40" y1="20" x2="40" y2="180" stroke="#475569" stroke-width="1"/>
              <line x1="40" y1="180" x2="380" y2="180" stroke="#475569" stroke-width="1"/>
              
              <!-- Y-axis labels -->
              <text x="20" y="25" fill="#94a3b8" font-size="10">100%</text>
              <text x="25" y="65" fill="#94a3b8" font-size="10">75%</text>
              <text x="25" y="105" fill="#94a3b8" font-size="10">50%</text>
              <text x="25" y="145" fill="#94a3b8" font-size="10">25%</text>
              <text x="30" y="185" fill="#94a3b8" font-size="10">0%</text>
              
              <!-- X-axis labels -->
              <text x="60" y="195" fill="#94a3b8" font-size="10">00:00</text>
              <text x="140" y="195" fill="#94a3b8" font-size="10">06:00</text>
              <text x="220" y="195" fill="#94a3b8" font-size="10">12:00</text>
              <text x="300" y="195" fill="#94a3b8" font-size="10">18:00</text>
              
              <!-- Humidity line -->
              <polyline
                points="40,100 80,95 120,105 160,90 200,85 240,100 280,110 320,105 360,100"
                fill="none"
                stroke="#10b981"
                stroke-width="2"
              />
              
              <!-- Data points -->
              <circle cx="40" cy="100" r="3" fill="#10b981"/>
              <circle cx="80" cy="95" r="3" fill="#10b981"/>
              <circle cx="120" cy="105" r="3" fill="#10b981"/>
              <circle cx="160" cy="90" r="3" fill="#10b981"/>
              <circle cx="200" cy="85" r="3" fill="#10b981"/>
              <circle cx="240" cy="100" r="3" fill="#10b981"/>
              <circle cx="280" cy="110" r="3" fill="#10b981"/>
              <circle cx="320" cy="105" r="3" fill="#10b981"/>
              <circle cx="360" cy="100" r="3" fill="#10b981"/>
            </svg>
          </div>
        </div>
      </div>
      
      <!-- Recent Activity -->
      <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
        <h2 class="text-xl font-bold text-white mb-4 font-heading">Recent Activity</h2>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-3 bg-slate-900 rounded-md">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-green-400 rounded-full"></div>
              <span class="text-white">Device DEV-001 came online</span>
            </div>
            <span class="text-slate-400 text-sm">2 minutes ago</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-slate-900 rounded-md">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-yellow-400 rounded-full"></div>
              <span class="text-white">Temperature alert: DEV-005 exceeded threshold</span>
            </div>
            <span class="text-slate-400 text-sm">15 minutes ago</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-slate-900 rounded-md">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-red-400 rounded-full"></div>
              <span class="text-white">Device DEV-012 went offline</span>
            </div>
            <span class="text-slate-400 text-sm">1 hour ago</span>
          </div>
          <div class="flex items-center justify-between p-3 bg-slate-900 rounded-md">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-blue-400 rounded-full"></div>
              <span class="text-white">New user registered: user@example.com</span>
            </div>
            <span class="text-slate-400 text-sm">3 hours ago</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

