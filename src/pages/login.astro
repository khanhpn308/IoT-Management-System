
---
import MainLayout from '../layouts/main.astro';
import { ArrowLeft } from 'lucide-react';
import { baseUrl } from '../lib/base-url';
---

<MainLayout>
  <div class="min-h-screen bg-slate-900 flex items-center justify-center px-4">
    <!-- Back to Home Button -->
    <a 
      href={`${baseUrl}/`}
      class="fixed top-4 left-4 flex items-center gap-2 text-slate-400 hover:text-white transition-colors z-50"
    >
      <ArrowLeft className="w-5 h-5" />
      <span class="text-sm">Back to Home</span>
    </a>
    
    <div class="max-w-md w-full">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-white mb-2 font-heading">IoT Manager</h1>
        <p class="text-slate-400">Sign in to your account</p>
      </div>
      
      <div class="bg-slate-800 border border-slate-700 rounded-lg p-8">
        <form class="space-y-6">
          <div>
            <label for="email" class="block text-sm font-medium text-slate-300 mb-2">
              Email Address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 bg-slate-900 border border-slate-600 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="you@example.com"
            />
          </div>
          
          <div>
            <label for="password" class="block text-sm font-medium text-slate-300 mb-2">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full px-4 py-3 bg-slate-900 border border-slate-600 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              placeholder="••••••••"
            />
          </div>
          
          <div class="flex items-center justify-between">
            <label class="flex items-center">
              <input
                type="checkbox"
                class="w-4 h-4 text-blue-500 bg-slate-700 border-slate-600 rounded focus:ring-blue-500"
              />
              <span class="ml-2 text-sm text-slate-400">Remember me</span>
            </label>
            
            <a href={`${baseUrl}/recover-password`} class="text-sm text-blue-400 hover:text-blue-300">
              Forgot password?
            </a>
          </div>
          
          <button
            type="submit"
            class="w-full bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-md font-medium transition-colors"
          >
            Sign In
          </button>
        </form>
        
        <div class="mt-6 text-center">
          <p class="text-sm text-slate-400">
            Don't have an account?
            <a href={`${baseUrl}/register`} class="text-blue-400 hover:text-blue-300 ml-1">
              Sign up
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { baseUrl } from '../lib/base-url';
  
  document.querySelector('form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Login successful!');
    window.location.href = `${baseUrl}/dashboard`;
  });
</script>

