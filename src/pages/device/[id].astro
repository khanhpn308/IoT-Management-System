
---
import MainLayout from '../../layouts/main.astro';
import Navbar from '../../components/Navbar';
import { Edit, Activity, Key } from 'lucide-react';

const { id } = Astro.params;

// Mock device data
const device = {
  id: id,
  name: `Device ${id}`,
  password: '********',
  status: 'Online',
  location: 'Warehouse North',
  lastSeen: new Date().toISOString(),
};

// Mock history data
const history = Array.from({ length: 20 }, (_, i) => ({
  parameter: `${(Math.random() * 30 + 10).toFixed(2)}°C`,
  timestamp: new Date(Date.now() - i * 3600000).toISOString(),
}));
---

<MainLayout>
  <Navbar client:only="react" />
  
  <div class="min-h-screen bg-slate-900 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-4xl font-bold text-white mb-2 font-heading">{device.name}</h1>
        <div class="flex items-center gap-4">
          <span class="text-slate-400">Device ID: {device.id}</span>
          <div class="flex items-center gap-2 px-3 py-1 bg-green-500/20 text-green-400 rounded-full text-sm">
            <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
            {device.status}
          </div>
        </div>
      </div>
      
      <!-- Tabs -->
      <div class="mb-6">
        <div class="border-b border-slate-700">
          <nav class="flex space-x-8">
            <button
              data-tab="account"
              class="tab-btn py-4 px-1 border-b-2 border-blue-500 text-blue-400 font-medium text-sm flex items-center gap-2"
            >
              <Key className="w-4 h-4" />
              Account
            </button>
            <button
              data-tab="history"
              class="tab-btn py-4 px-1 border-b-2 border-transparent text-slate-400 hover:text-white font-medium text-sm flex items-center gap-2"
            >
              <Activity className="w-4 h-4" />
              History
            </button>
          </nav>
        </div>
      </div>
      
      <!-- Account Tab -->
      <div id="account-tab" class="tab-content">
        <div class="bg-slate-800 border border-slate-700 rounded-lg p-6">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold text-white font-heading">Device Credentials</h2>
            <button id="editPasswordBtn" class="text-blue-400 hover:text-blue-300 transition-colors">
              <Edit className="w-5 h-5" />
            </button>
          </div>
          
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-2">Device ID</label>
              <div class="bg-slate-900 border border-slate-700 rounded-md px-4 py-3 text-white">
                {device.id}
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-2">Password</label>
              <div class="bg-slate-900 border border-slate-700 rounded-md px-4 py-3 text-white font-mono">
                {device.password}
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-2">Location</label>
              <div class="bg-slate-900 border border-slate-700 rounded-md px-4 py-3 text-white">
                {device.location}
              </div>
            </div>
            
            <div>
              <label class="block text-sm font-medium text-slate-400 mb-2">Last Seen</label>
              <div class="bg-slate-900 border border-slate-700 rounded-md px-4 py-3 text-white">
                {new Date(device.lastSeen).toLocaleString()}
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- History Tab -->
      <div id="history-tab" class="tab-content hidden">
        <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
          <div class="p-6 border-b border-slate-700">
            <h2 class="text-2xl font-bold text-white font-heading">Parameter History</h2>
          </div>
          
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead class="bg-slate-900">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                    Parameter Value
                  </th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                    Timestamp
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-700">
                {history.map((entry, index) => (
                  <tr class={index % 2 === 0 ? 'bg-slate-800' : 'bg-slate-850'}>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-white font-mono">
                      {entry.parameter}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                      {new Date(entry.timestamp).toLocaleString()}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Change Password Modal Container -->
  <div id="changePasswordModalRoot"></div>
</MainLayout>

<script define:vars={{ deviceId: id }}>
  // Tab switching
  const tabButtons = document.querySelectorAll('.tab-btn');
  const tabContents = document.querySelectorAll('.tab-content');
  
  tabButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tabName = button.getAttribute('data-tab');
      
      // Update button styles
      tabButtons.forEach(btn => {
        if (btn.getAttribute('data-tab') === tabName) {
          btn.classList.remove('border-transparent', 'text-slate-400');
          btn.classList.add('border-blue-500', 'text-blue-400');
        } else {
          btn.classList.remove('border-blue-500', 'text-blue-400');
          btn.classList.add('border-transparent', 'text-slate-400');
        }
      });
      
      // Update content visibility
      tabContents.forEach(content => {
        if (content.id === `${tabName}-tab`) {
          content.classList.remove('hidden');
        } else {
          content.classList.add('hidden');
        }
      });
    });
  });
  
  // Change password modal
  document.getElementById('editPasswordBtn')?.addEventListener('click', async () => {
    const { default: ChangePasswordModal } = await import('../../components/ChangePasswordModal');
    const { createRoot } = await import('react-dom/client');
    const { createElement } = await import('react');
    
    const container = document.getElementById('changePasswordModalRoot');
    if (!container) return;
    
    const root = createRoot(container);
    
    const handleClose = () => {
      root.unmount();
    };
    
    root.render(createElement(ChangePasswordModal, { 
      isOpen: true, 
      onClose: handleClose,
      deviceId: deviceId
    }));
  });
</script>

<style>
  .lucide {
    display: inline-block;
  }
</style>

