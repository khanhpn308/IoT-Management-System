
---
import MainLayout from '../layouts/main.astro';
import Navbar from '../components/Navbar';
import { UserCog, Trash2, Plus } from 'lucide-react';

const users = [
  { id: 'USR-001', email: 'john.doe@example.com', name: 'John Doe', role: 'User', devices: 3 },
  { id: 'USR-002', email: 'jane.smith@example.com', name: 'Jane Smith', role: 'User', devices: 5 },
  { id: 'USR-003', email: 'mike.wilson@example.com', name: 'Mike Wilson', role: 'User', devices: 2 },
  { id: 'USR-004', email: 'sarah.jones@example.com', name: 'Sarah Jones', role: 'Admin', devices: 8 },
  { id: 'USR-005', email: 'tom.brown@example.com', name: 'Tom Brown', role: 'User', devices: 4 },
  { id: 'USR-006', email: 'lisa.davis@example.com', name: 'Lisa Davis', role: 'User', devices: 1 },
  { id: 'USR-007', email: 'david.miller@example.com', name: 'David Miller', role: 'User', devices: 6 },
  { id: 'USR-008', email: 'emily.garcia@example.com', name: 'Emily Garcia', role: 'User', devices: 3 },
];
---

<MainLayout>
  <Navbar client:only="react" />
  
  <div class="min-h-screen bg-slate-900 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-4xl font-bold text-white font-heading">User Management</h1>
      </div>
      
      <!-- User Directory Table -->
      <div class="bg-slate-800 border border-slate-700 rounded-lg overflow-hidden">
        <div class="p-6 border-b border-slate-700">
          <h2 class="text-2xl font-bold text-white font-heading">User Directory</h2>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-slate-900">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                  User ID
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                  Name
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                  Email
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                  Role
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                  Devices
                </th>
                <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-700">
              {users.map((user, index) => (
                <tr class={index % 2 === 0 ? 'bg-slate-800' : 'bg-slate-850'}>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-white font-mono">
                    {user.id}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-white">
                    {user.name}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                    {user.email}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`px-3 py-1 rounded-full text-xs font-medium ${user.role === 'Admin' ? 'bg-purple-500/20 text-purple-400' : 'bg-blue-500/20 text-blue-400'}`}>
                      {user.role}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-400">
                    {user.devices} devices
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm">
                    <div class="flex items-center gap-3">
                      <button
                        class="assign-btn text-blue-400 hover:text-blue-300 transition-colors"
                        data-user-id={user.id}
                        title="Assign Devices"
                      >
                        <UserCog className="w-5 h-5" />
                      </button>
                      <button
                        class="delete-btn text-red-400 hover:text-red-300 transition-colors"
                        data-user-id={user.id}
                        title="Delete User"
                      >
                        <Trash2 className="w-5 h-5" />
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Floating Add Button -->
  <button
    id="addUserBtn"
    class="fixed bottom-8 right-8 w-16 h-16 bg-blue-500 hover:bg-blue-600 text-white rounded-full shadow-lg hover:shadow-xl transition-all flex items-center justify-center z-40"
    title="Add New Device"
  >
    <Plus className="w-8 h-8" />
  </button>
  
  <!-- Assign Device Modal Container -->
  <div id="assignDeviceModalRoot"></div>
</MainLayout>

<script>
  // Assign device handlers
  const assignButtons = document.querySelectorAll('.assign-btn');
  assignButtons.forEach(button => {
    button.addEventListener('click', async () => {
      const userId = button.getAttribute('data-user-id');
      if (!userId) return;
      
      const { default: AssignDeviceModal } = await import('../components/AssignDeviceModal');
      const { createRoot } = await import('react-dom/client');
      const { createElement } = await import('react');
      
      const container = document.getElementById('assignDeviceModalRoot');
      if (!container) return;
      
      const root = createRoot(container);
      
      const handleClose = () => {
        root.unmount();
      };
      
      root.render(createElement(AssignDeviceModal, { 
        isOpen: true, 
        onClose: handleClose,
        userId: userId
      }));
    });
  });
  
  // Delete user handlers
  const deleteButtons = document.querySelectorAll('.delete-btn');
  deleteButtons.forEach(button => {
    button.addEventListener('click', () => {
      const userId = button.getAttribute('data-user-id');
      if (confirm(`Are you sure you want to delete user ${userId}?`)) {
        alert(`User ${userId} deleted successfully`);
      }
    });
  });
  
  // Add device button
  document.getElementById('addUserBtn')?.addEventListener('click', async () => {
    const { default: AddDeviceModal } = await import('../components/AddDeviceModal');
    const { createRoot } = await import('react-dom/client');
    const { createElement } = await import('react');
    
    const container = document.getElementById('assignDeviceModalRoot');
    if (!container) return;
    
    const root = createRoot(container);
    
    const handleClose = () => {
      root.unmount();
    };
    
    root.render(createElement(AddDeviceModal, { isOpen: true, onClose: handleClose }));
  });
</script>

<style>
  .lucide {
    display: inline-block;
  }
</style>

